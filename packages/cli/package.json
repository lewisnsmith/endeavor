    "lint": "eslint src",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@endeavor/shared-types": "*",
    "@endeavor/integrations": "*",
    "commander": "^13.1.0"
  }
}
