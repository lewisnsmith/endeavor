{
  "name": "@endeavor/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "endeavor": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/index.ts",
