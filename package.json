{
  "name": "endeavor",
  "version": "0.2.0",
  "private": true,
  "description": "Terminal-native coordination for parallel Claude Code work.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm --workspace @endeavor/core run build && npm --workspace @endeavor/cli --workspace @endeavor/daemon run build",
    "lint": "npm run -ws --if-present lint",
    "test": "npm run -ws --if-present test",
    "typecheck": "npm run -ws --if-present typecheck",
    "clean": "npm run -ws --if-present clean",
    "dev:cli": "npm --workspace @endeavor/cli run dev",
    "dev:daemon": "npm --workspace @endeavor/daemon run dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
